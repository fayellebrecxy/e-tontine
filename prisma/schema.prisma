// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  
}



enum Role {
  ADMIN
  MEMBRE
  UTILISATEUR
}

enum StatutAdhesion {
  ACTIF
  INACTIF
  EN_ATTENTE
}

enum StatutVisuel {
  EN_LIGNE
  HORS_LIGNE
}

// --- MODELES ---

model User {
  id_user         String            @id @default(uuid())
  nom             String
  prenom          String
  email           String         @unique
  telephone       String         @unique
  mot_de_passe    String
  photo_de_profil String?
  nom_groupe      String?
  role            Role           @default(UTILISATEUR)
  statut_adhesion StatutAdhesion @default(EN_ATTENTE)
  date_adhesion   DateTime       @default(now())
  date_depart     DateTime?
  statut_visuel   StatutVisuel   @default(HORS_LIGNE)
  
  // Relations
  cotisations     Cotisations[]
  penalites       Penalite[]
  groupes         Groupes[] @relation("UserGroupe")

  @@map("users")
}


model Groupes {
  id_groupe        String         @id @default(uuid())
  nom              String
  description      String?
  devise           String         @default("XAF")
  lien_invitation  String?        @unique
  date_de_creation DateTime       @default(now())

  // Relations

  cycles           CycleTontine[]
  user             User[] @relation("UserGroupe")   

  @@map("groupes")
}


model CycleTontine {
  id_cycle           String           @id @default(uuid())
  nom_cycle          String
  date_debut         DateTime         @default(now())
  date_fin           DateTime
  duree_tour_de_gain Int
  ordre_beneficiaire String?
  
  id_groupe          String
  groupe             Groupes        @relation(fields: [id_groupe], references: [id_groupe], onDelete: Cascade)
  cotisations        Cotisations[]

  @@index([id_groupe])
  @@map("cycles_tontine")
}


model Cotisations {
  id_cotisation      String           @id @default(uuid())
  date_debut         DateTime
  montant            Decimal       @db.Decimal(15, 2)
  date_de_paiement   DateTime
  penalite_appliquee Boolean       @default(false)
  montant_penalite   Decimal?      @db.Decimal(15, 2)

  id_user            String
  user               User          @relation(fields: [id_user],references: [id_user])
  id_cycle           String
  cycle              CycleTontine  @relation(fields: [id_cycle], references: [id_cycle])

  penalite          Penalite[]
  Penalite         Penalite[]   @relation("PenaliteCotisations")

  @@index([id_cycle])
  @@map("cotisations")
}


model Penalite {
  id_penalite              String       @id @default(uuid())
  montant_base             Decimal      @db.Decimal(15, 2)
  motif                    String
  taux_augmentation_heure  Decimal     @db.Decimal(5, 2)
  seuil_heure_augmentation Int
  date_application         DateTime
  montant_final            Decimal     @db.Decimal(15, 2)

  // Relations
  id_user                  String
  user                     User        @relation(fields: [id_user], references: [id_user])
  id_cotisation            String
  cotisations              Cotisations @relation(fields: [id_cotisation], references: [id_cotisation])
  Cotisations              Cotisations[] @relation("PenaliteCotisations")

  @@index([id_user])
  @@map("penalites")
}


